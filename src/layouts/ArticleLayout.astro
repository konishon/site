---
const {
  title,
  description,
  category,
  readingTime,
  published,
  publishedISO,
  hero,
  heroAlt,
  heroCaption,
  sourceUrl,
  sourceLabel = "View source on GitHub",
  contents = []
} = Astro.props;
const site = Astro.site ?? new URL("https://nishon.com.np");
const canonicalUrl = new URL(Astro.url.pathname, site);
const heroUrl = new URL(hero, site);
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: title,
  description,
  datePublished: publishedISO,
  dateModified: publishedISO,
  image: heroUrl.href,
  url: canonicalUrl.href,
  mainEntityOfPage: canonicalUrl.href,
  inLanguage: "en",
  author: {
    "@type": "Person",
    name: "Nishon Tandukar",
    url: site.href,
    sameAs: [
      "https://github.com/konishon",
      "https://medium.com/@niyo177",
      "https://www.linkedin.com/in/nishon-tandukar/",
      "https://www.instagram.com/life.of.nishon/"
    ],
    knowsAbout: ["GeoAI", "OpenStreetMap", "spatial data infrastructure", "Python", "humanitarian technology"]
  },
  publisher: {
    "@type": "Person",
    name: "Nishon Tandukar",
    url: site.href
  },
  keywords: category
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content={description}>
  <meta name="author" content="Nishon Tandukar">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <link rel="canonical" href={canonicalUrl}>
  <link rel="alternate" type="application/rss+xml" title="Nishon Notes" href={new URL("feed.xml", site)}>
  <meta property="og:title" content={`${title} — Nishon Tandukar`}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="article">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:site_name" content="Nishon Notes">
  <meta property="og:image" content={heroUrl}>
  <meta property="article:published_time" content={publishedISO}>
  <meta property="article:author" content="Nishon Tandukar">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={heroUrl}>
  <meta name="theme-color" content="#ffffff">
  <script is:inline>
    (() => {
      const saved = localStorage.getItem("nishon-theme");
      const mode = ["light", "dark", "auto"].includes(saved) ? saved : "auto";
      document.documentElement.dataset.themeMode = mode;
      document.documentElement.dataset.theme = mode === "auto"
        ? (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
        : mode;
    })();
  </script>
  <title>{title} — Nishon Tandukar</title>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&family=DM+Serif+Display:ital@0;1&family=Manrope:wght@700;800&display=swap" rel="stylesheet">
  <style>
    :root{--ink:#333132;--muted:#6f7278;--paper:#fff;--card:#f4f4f4;--line:#e6e6e6;--accent:#0055ff;--gold:#ffab00}
    html[data-theme="dark"]{--ink:#f4f4f4;--muted:#a9adb7;--paper:#11131a;--card:#1a1e29;--line:#303542;--accent:#738dff;--gold:#ffb100;color-scheme:dark}
    *{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;color:var(--ink);background:var(--paper);font:400 18px/1.78 "DM Sans",sans-serif;-webkit-font-smoothing:antialiased}html[data-theme="dark"] body{background:radial-gradient(circle at 12% 0,rgba(0,85,255,.16),transparent 34rem),var(--paper)}a{color:inherit;text-decoration:none}.shell{width:min(1140px,calc(100% - 40px));margin-inline:auto}
    .nav{position:sticky;top:0;z-index:20;isolation:isolate;display:flex;align-items:center;justify-content:space-between;width:min(1140px,calc(100% - 40px));margin:0 auto;padding:18px 0;border-bottom:1px solid var(--line);backdrop-filter:blur(16px)}.nav::before{content:"";position:absolute;z-index:-1;inset:0 auto;left:50%;width:100vw;transform:translateX(-50%);background:rgba(255,255,255,.92)}html[data-theme="dark"] .nav::before{background:rgba(17,19,26,.92)}.logo{font:800 15px/1 "Manrope",sans-serif;letter-spacing:-.04em}.logo span{color:var(--gold)}.nav-links{display:flex;align-items:center;gap:24px;color:#505249;font-size:14px;font-weight:600}html[data-theme="dark"] .nav-links{color:#c2c5ce}.nav-links a{display:inline-flex;align-items:center;min-height:44px}.nav-links a:hover{color:var(--accent)}.theme-toggle{display:inline-grid;place-items:center;width:44px;height:44px;padding:0;border:1px solid var(--line);border-radius:50%;color:var(--ink);background:transparent;cursor:pointer}.theme-toggle:hover{border-color:var(--accent);color:var(--accent)}.theme-toggle span{display:none}html[data-theme-mode="auto"] .theme-toggle .auto,html[data-theme-mode="light"] .theme-toggle .sun,html[data-theme-mode="dark"] .theme-toggle .moon{display:block}.theme-toggle .auto{font:700 10px/1 "Manrope",sans-serif;letter-spacing:.04em}
    .article-head{padding:76px 0 48px}.meta{display:flex;flex-wrap:wrap;gap:12px;color:var(--muted);font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase}.meta span:first-child{color:var(--accent)}h1,h2,h3{margin:0}h1{max-width:1080px;margin:20px 0 24px;font:400 clamp(58px,8vw,104px)/.92 "DM Serif Display",serif;letter-spacing:-.045em}.dek{max-width:790px;margin:0;color:var(--muted);font-size:clamp(20px,2.4vw,27px);line-height:1.5}.byline{display:flex;align-items:center;gap:14px;margin-top:32px;padding-top:20px;border-top:1px solid var(--line);font-size:14px}.avatar{width:44px;height:44px;border-radius:50%;object-fit:cover}.byline strong{display:block}.byline span{color:var(--muted)}
    .hero-visual{margin:0;background:#080b13}.hero-visual img{display:block;width:100%;height:min(710px,66vw);min-height:420px;object-fit:contain}.hero-visual figcaption{display:flex;justify-content:space-between;gap:24px;width:min(1140px,calc(100% - 40px));margin:auto;padding:15px 0;color:#a9adb7;font-size:12px}.hero-visual figcaption a{color:#97a9ff;font-weight:700}
    .layout{display:grid;grid-template-columns:220px minmax(0,720px);gap:80px;justify-content:center;padding:90px 0 120px}.toc{position:sticky;top:110px;align-self:start;font-size:13px}.toc strong{display:block;margin-bottom:14px;font-size:11px;letter-spacing:.12em;text-transform:uppercase}.toc a{display:block;padding:5px 0;color:var(--muted)}.toc a:hover{color:var(--accent)}article p{margin:0 0 28px}article h2{margin:72px 0 22px;font:400 clamp(38px,4vw,52px)/1.05 "DM Serif Display",serif;letter-spacing:-.035em}article h3{margin:42px 0 15px;font:700 22px/1.3 "Manrope",sans-serif;letter-spacing:-.025em}article ul,article ol{margin:0 0 30px;padding-left:24px}article li{margin:8px 0}article a{text-decoration:underline;text-decoration-color:rgba(0,85,255,.45);text-underline-offset:3px}.lead{font-size:21px;color:#45483f}html[data-theme="dark"] .lead{color:#c8cbd3}.question{margin:38px 0;padding:30px;border-left:4px solid var(--gold);background:var(--card);font:400 31px/1.3 "DM Serif Display",serif}.flow{margin:38px 0;padding:28px;border-radius:18px;background:#090b11;color:#eef0f5;font:500 14px/1.9 "DM Mono",monospace;white-space:pre-wrap}.facts{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;margin:38px 0;border:1px solid var(--line);background:var(--line)}.fact{padding:24px;background:var(--paper)}.fact strong{display:block;color:var(--accent);font:400 34px/1 "DM Serif Display",serif}.fact span{display:block;margin-top:8px;color:var(--muted);font-size:13px}.callout{margin:38px 0;padding:28px;border:1px solid var(--line);border-radius:18px;background:var(--card)}.callout strong{display:block;margin-bottom:8px;color:var(--accent);font-size:12px;letter-spacing:.1em;text-transform:uppercase}code{padding:.12em .34em;border-radius:4px;background:var(--card);font-family:"DM Mono",monospace;font-size:.85em}pre{overflow:auto;margin:30px 0;padding:25px;border-radius:18px;background:#090b11;color:#eef0f5;font:400 13px/1.7 "DM Mono",monospace}pre code{padding:0;background:none;color:inherit}.repo-link{display:inline-flex;align-items:center;min-height:48px;padding:0 22px;border-radius:999px;background:var(--accent);color:white;font-size:15px;font-weight:700;text-decoration:none}.article-end{padding:70px 0;text-align:center;border-top:1px solid var(--line)}.article-end h2{max-width:720px;margin:8px auto 25px;font:400 clamp(38px,5vw,60px)/1 "DM Serif Display",serif}footer{display:flex;justify-content:space-between;gap:20px;padding:26px 0;border-top:1px solid var(--line);color:var(--muted);font-size:13px}.footer-links{display:flex;gap:20px}:focus-visible{outline:3px solid rgba(0,85,255,.38);outline-offset:4px}
    html[data-theme="dark"] .fact,html[data-theme="dark"] .question,html[data-theme="dark"] .callout{background:#171a23}html[data-theme="dark"] .flow,html[data-theme="dark"] pre{box-shadow:inset 0 0 0 1px #2b3140}
    @media(max-width:820px){.layout{grid-template-columns:minmax(0,720px)}.toc{display:none}}@media(max-width:560px){body{font-size:17px}.shell,.nav{width:min(100% - 24px,1140px)}.nav-links a:not(.back){display:none}.theme-toggle{width:40px;height:40px}.article-head{padding:65px 0 42px}h1{font-size:54px}.hero-visual img{min-height:330px}.hero-visual figcaption{width:calc(100% - 24px);flex-direction:column}.layout{padding:62px 0 88px}.facts{grid-template-columns:1fr}.question,.callout{padding:24px}footer{flex-direction:column}}
  </style>
</head>
<body>
  <nav class="nav" aria-label="Article navigation">
    <a class="logo" href="index.html">NISHON<span>•</span>NOTES</a>
    <div class="nav-links"><a href="index.html#writing">All writing</a><a class="back" href="index.html">← Home</a><button class="theme-toggle" type="button" aria-label="Theme: Auto, following device settings" title="Theme: Auto (device)"><span class="auto" aria-hidden="true">AUTO</span><span class="sun" aria-hidden="true">☼</span><span class="moon" aria-hidden="true">☾</span></button></div>
  </nav>
  <main>
  <header class="article-head shell">
    <div class="meta"><span>{category}</span><span>{readingTime}</span><span>{published}</span></div>
    <h1>{title}</h1>
    <p class="dek">{description}</p>
    <div class="byline"><img class="avatar" src="assets/nishon-tandukar.jpg" alt=""><div><strong>Nishon Tandukar</strong><span>GeoAI research and data specialist</span></div></div>
  </header>
  <figure class="hero-visual">
    <img src={hero} alt={heroAlt}>
    <figcaption><span>{heroCaption}</span><a href={sourceUrl} target="_blank" rel="noopener">{sourceLabel} ↗</a></figcaption>
  </figure>
  <div class="layout shell">
    <aside class="toc" aria-label="Article contents"><strong>In this article</strong>{contents.map((item) => <a href={`#${item.id}`}>{item.label}</a>)}</aside>
    <article><slot /></article>
  </div>
  </main>
  <section class="article-end"><div class="shell"><div class="meta" style="justify-content:center"><span>Keep reading</span></div><h2>More notes on maps, data, and applied technology.</h2><a class="repo-link" href="index.html#writing">Browse all writing →</a></div></section>
  <footer class="shell"><span>© <span id="year"></span> Nishon Tandukar</span><div class="footer-links"><a href="index.html#writing">Archive</a><a href="https://www.linkedin.com/in/nishon-tandukar/" target="_blank" rel="noopener">LinkedIn</a><a href="https://www.instagram.com/life.of.nishon/" target="_blank" rel="noopener">Instagram</a><a href="mailto:hello@nishon.com.np">Email</a></div></footer>
  <script>
    document.getElementById("year").textContent = new Date().getFullYear();
    const themeToggle = document.querySelector(".theme-toggle");
    const deviceTheme = matchMedia("(prefers-color-scheme: dark)");
    const themeModes = ["auto", "light", "dark"];
    function applyThemeMode(mode, save = true) {
      const theme = mode === "auto" ? (deviceTheme.matches ? "dark" : "light") : mode;
      document.documentElement.dataset.themeMode = mode;
      document.documentElement.dataset.theme = theme;
      if (save) localStorage.setItem("nishon-theme", mode);
      syncThemeToggle();
    }
    function syncThemeToggle() {
      const mode = document.documentElement.dataset.themeMode || "auto";
      const dark = document.documentElement.dataset.theme === "dark";
      const next = themeModes[(themeModes.indexOf(mode) + 1) % themeModes.length];
      const label = mode === "auto" ? "Auto, following device settings" : mode[0].toUpperCase() + mode.slice(1);
      themeToggle.setAttribute("aria-label", `Theme: ${label}. Switch to ${next}`);
      themeToggle.setAttribute("title", `Theme: ${label}`);
      document.querySelector('meta[name="theme-color"]').content = dark ? "#11131a" : "#ffffff";
    }
    themeToggle.addEventListener("click", () => {
      const mode = document.documentElement.dataset.themeMode || "auto";
      applyThemeMode(themeModes[(themeModes.indexOf(mode) + 1) % themeModes.length]);
    });
    deviceTheme.addEventListener("change", () => {
      if (document.documentElement.dataset.themeMode === "auto") applyThemeMode("auto", false);
    });
    syncThemeToggle();
  </script>
</body>
</html>
