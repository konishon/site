  <script>
    document.getElementById("year").textContent = new Date().getFullYear();
    const filters = document.querySelectorAll(".filter");
    const posts = document.querySelectorAll(".post-card");
    filters.forEach((button) => {
      button.addEventListener("click", () => {
        filters.forEach((item) => item.classList.remove("active"));
        button.classList.add("active");
        const topic = button.dataset.filter;
        posts.forEach((post) => {
          post.hidden = topic !== "all" && post.dataset.topic !== topic;
        });
      });
    });

    const canvas = document.getElementById("geo-globe");
    const context = canvas.getContext("2d");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let rotation = -0.55;
    let frame;
    let startTime = performance.now();

    function spherePoint(latitude, longitude, radius) {
      const lat = latitude * Math.PI / 180;
      const lon = (longitude * Math.PI / 180) + rotation;
      return {
        x: radius * Math.cos(lat) * Math.sin(lon),
        y: -radius * Math.sin(lat),
        z: radius * Math.cos(lat) * Math.cos(lon)
      };
    }

    function project(point, center, radius) {
      const perspective = 2.7 / (3.7 - point.z / radius);
      return {
        x: center + point.x * perspective,
        y: center + point.y * perspective,
        z: point.z,
        scale: perspective
      };
    }

    function drawPath(points, center, radius, color, width) {
      let drawing = false;
      context.beginPath();
      points.forEach((point) => {
        const projected = project(point, center, radius);
        if (point.z > -radius * .16) {
          if (!drawing) context.moveTo(projected.x, projected.y);
          else context.lineTo(projected.x, projected.y);
          drawing = true;
        } else {
          drawing = false;
        }
      });
      context.strokeStyle = color;
      context.lineWidth = width;
      context.stroke();
    }

    function drawScanWindow(center, radius, elapsed) {
      const dark = document.documentElement.dataset.theme === "dark";
      const scanRgb = dark ? "255,177,0" : "0,85,255";
      const progress = reducedMotion ? .5 : (Math.sin(elapsed * .00072) + 1) / 2;
      const windowWidth = radius * .52;
      const scanX = center - radius + progress * (radius * 2);
      const left = scanX - windowWidth / 2;

      context.save();
      context.beginPath();
      context.arc(center, center, radius - 1, 0, Math.PI * 2);
      context.clip();

      const wash = context.createLinearGradient(left, 0, left + windowWidth, 0);
      wash.addColorStop(0, `rgba(${scanRgb},0)`);
      wash.addColorStop(.18, `rgba(${scanRgb},${dark ? .025 : .05})`);
      wash.addColorStop(.5, dark ? "rgba(115,141,255,.075)" : "rgba(255,255,255,.22)");
      wash.addColorStop(.82, `rgba(${scanRgb},${dark ? .025 : .05})`);
      wash.addColorStop(1, `rgba(${scanRgb},0)`);
      context.fillStyle = wash;
      context.fillRect(left, center - radius, windowWidth, radius * 2);

      context.beginPath();
      context.rect(left, center - radius, windowWidth, radius * 2);
      context.clip();

      for (let lat = -70; lat <= 70; lat += 10) {
        const points = [];
        for (let lon = -180; lon <= 180; lon += 2) points.push(spherePoint(lat, lon, radius));
        drawPath(points, center, radius, dark ? "rgba(255,177,0,.075)" : "rgba(0,85,255,.17)", .7);
      }

      context.restore();

      const edgeFade = Math.max(0, 1 - Math.abs(scanX - center) / radius);
      context.save();
      context.beginPath();
      context.arc(center, center, radius - 1, 0, Math.PI * 2);
      context.clip();
      context.strokeStyle = `rgba(${scanRgb},${dark ? .12 + edgeFade * .2 : .22 + edgeFade * .28})`;
      context.lineWidth = 1.4;
      context.strokeRect(left, center - radius, windowWidth, radius * 2);
      context.beginPath();
      context.moveTo(scanX, center - radius);
      context.lineTo(scanX, center + radius);
      context.strokeStyle = `rgba(${scanRgb},${dark ? .28 + edgeFade * .3 : .3 + edgeFade * .35})`;
      context.lineWidth = 1;
      context.stroke();
      context.restore();
    }

    function drawGlobe(timestamp = performance.now()) {
      const dark = document.documentElement.dataset.theme === "dark";
      const bounds = canvas.getBoundingClientRect();
      const ratio = Math.min(window.devicePixelRatio || 1, 2);
      const size = Math.max(1, Math.round(bounds.width));
      if (canvas.width !== size * ratio) {
        canvas.width = size * ratio;
        canvas.height = size * ratio;
      }
      context.setTransform(ratio, 0, 0, ratio, 0, 0);
      context.clearRect(0, 0, size, size);

      const center = size / 2;
      const radius = size * .34;
      const glow = context.createRadialGradient(center - radius * .28, center - radius * .35, radius * .05, center, center, radius * 1.05);
      glow.addColorStop(0, dark ? "rgba(115,141,255,.12)" : "rgba(255,255,255,.78)");
      glow.addColorStop(.55, dark ? "rgba(0,85,255,.055)" : "rgba(0,85,255,.1)");
      glow.addColorStop(1, dark ? "rgba(255,177,0,.012)" : "rgba(255,171,0,.04)");
      context.beginPath();
      context.arc(center, center, radius, 0, Math.PI * 2);
      context.fillStyle = glow;
      context.fill();
      context.strokeStyle = dark ? "rgba(115,141,255,.32)" : "rgba(0,26,203,.27)";
      context.lineWidth = 1.3;
      context.stroke();

      for (let lat = -60; lat <= 60; lat += 20) {
        const points = [];
        for (let lon = -180; lon <= 180; lon += 3) points.push(spherePoint(lat, lon, radius));
        drawPath(points, center, radius, dark ? "rgba(115,141,255,.18)" : "rgba(0,26,203,.22)", 1);
      }
      for (let lon = -180; lon < 180; lon += 20) {
        const points = [];
        for (let lat = -90; lat <= 90; lat += 3) points.push(spherePoint(lat, lon, radius));
        drawPath(points, center, radius, dark ? "rgba(115,141,255,.14)" : "rgba(0,26,203,.19)", 1);
      }

      drawScanWindow(center, radius, timestamp - startTime);

      [
        [27.7172, 85.3240, 4.6],
        [28.6139, 77.2090, 3.2],
        [52.0116, 4.3571, 3.2],
        [46.5197, 6.6323, 3.2],
        [1.3521, 103.8198, 3.2],
        [-1.2921, 36.8219, 3.2]
      ].forEach(([lat, lon, dot]) => {
        const point = spherePoint(lat, lon, radius);
        if (point.z < 0) return;
        const p = project(point, center, radius);
        context.beginPath();
        context.arc(p.x, p.y, dot * p.scale, 0, Math.PI * 2);
        context.fillStyle = lat === 27.7172 ? (dark ? "#ffb100" : "#ffab00") : (dark ? "rgba(151,169,255,.7)" : "rgba(0,85,255,.7)");
        context.fill();
        if (lat === 27.7172) {
          context.beginPath();
          context.arc(p.x, p.y, (dark ? 8 : 11) * p.scale, 0, Math.PI * 2);
          context.strokeStyle = dark ? "rgba(255,177,0,.3)" : "rgba(255,171,0,.42)";
          context.lineWidth = dark ? 1 : 1.2;
          context.stroke();
        }
      });

      if (!reducedMotion) {
        rotation += .00135;
        frame = requestAnimationFrame(drawGlobe);
      }
    }

    drawGlobe();
    window.addEventListener("resize", () => {
      if (frame) cancelAnimationFrame(frame);
      drawGlobe();
    });

    const themeToggle = document.querySelector(".theme-toggle");
    const deviceTheme = matchMedia("(prefers-color-scheme: dark)");
    const themeModes = ["auto", "light", "dark"];
    function applyThemeMode(mode, save = true) {
      const theme = mode === "auto" ? (deviceTheme.matches ? "dark" : "light") : mode;
      document.documentElement.dataset.themeMode = mode;
      document.documentElement.dataset.theme = theme;
      if (save) localStorage.setItem("nishon-theme", mode);
      syncThemeToggle();
      if (reducedMotion) drawGlobe();
    }
    function syncThemeToggle() {
      const mode = document.documentElement.dataset.themeMode || "auto";
      const dark = document.documentElement.dataset.theme === "dark";
      const next = themeModes[(themeModes.indexOf(mode) + 1) % themeModes.length];
      const label = mode === "auto" ? "Auto, following device settings" : mode[0].toUpperCase() + mode.slice(1);
      themeToggle.setAttribute("aria-label", `Theme: ${label}. Switch to ${next}`);
      themeToggle.setAttribute("title", `Theme: ${label}`);
      document.querySelector('meta[name="theme-color"]').content = dark ? "#11131a" : "#ffffff";
    }
    themeToggle.addEventListener("click", () => {
      const mode = document.documentElement.dataset.themeMode || "auto";
      applyThemeMode(themeModes[(themeModes.indexOf(mode) + 1) % themeModes.length]);
    });
    deviceTheme.addEventListener("change", () => {
      if (document.documentElement.dataset.themeMode === "auto") applyThemeMode("auto", false);
    });
    syncThemeToggle();
  </script>
