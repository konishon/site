---
const siteUrl = new URL("https://nishon.com.np");
const siteTitle = "Nishon Tandukar | Geospatial Software Engineer in Nepal";
const heroDescription = "Geospatial Software Engineer in Nepal building geoprocessing workflows, spatial data systems, geospatial data pipelines, and GeoAI workflows.";
const homeSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteUrl.href}#nishon`,
      name: "Nishon Tandukar",
      url: siteUrl.href,
      image: new URL("assets/nishon-tandukar.jpg", siteUrl).href,
      description: heroDescription,
      jobTitle: ["Geospatial Software Engineer", "Director of Geospatial Intelligence"],
      homeLocation: { "@type": "Country", name: "Nepal" },
      worksFor: { "@id": `${siteUrl.href}#naxa` },
      sameAs: [
        "https://github.com/konishon",
        "https://medium.com/@niyo177",
        "https://www.linkedin.com/in/nishon-tandukar/",
        "https://www.instagram.com/life.of.nishon/"
      ],
      knowsAbout: ["GeoAI workflows", "geospatial data pipelines", "geoprocessing workflows", "OpenStreetMap", "spatial data infrastructure", "humanitarian mapping"]
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl.href}#naxa`,
      name: "NAXA",
      url: "https://naxa.com.np/",
      logo: new URL("assets/naxa-logo.png", siteUrl).href,
      employee: { "@id": `${siteUrl.href}#nishon` }
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl.href}#website`,
      name: "Nishon Notes",
      url: siteUrl.href,
      description: "Technical writing by Nishon Tandukar on GeoAI, open mapping, spatial data, and software.",
      inLanguage: "en",
      author: { "@id": `${siteUrl.href}#nishon` }
    },
    {
      "@type": "ProfilePage",
      "@id": `${siteUrl.href}#profile`,
      url: siteUrl.href,
      name: siteTitle,
      description: heroDescription,
      isPartOf: { "@id": `${siteUrl.href}#website` },
      mainEntity: { "@id": `${siteUrl.href}#nishon` }
    },
    {
      "@type": "Blog",
      name: "Nishon Notes",
      url: siteUrl.href,
      author: { "@id": `${siteUrl.href}#nishon` },
      blogPost: [
        "building-a-public-nepal-earthquake-dataset",
        "finding-nepals-local-level-from-a-coordinate",
        "visualizing-pathfinding-on-openstreetmap",
        "reading-the-landscape-with-ai"
      ].map((slug) => ({ "@type": "BlogPosting", url: new URL(`${slug}.html`, siteUrl).href }))
    }
  ]
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content={heroDescription}>
  <meta name="author" content="Nishon Tandukar">
  <meta name="keywords" content="geospatial software engineering Nepal, GeoAI workflows, geospatial data pipelines, geoprocessing workflows, spatial data systems">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <link rel="canonical" href={siteUrl}>
  <link rel="alternate" type="application/rss+xml" title="Nishon Notes" href={new URL("feed.xml", siteUrl)}>
  <link rel="alternate" type="text/markdown" title="AI-readable site summary" href={new URL("llms.txt", siteUrl)}>
  <meta property="og:title" content={siteTitle}>
  <meta property="og:description" content={heroDescription}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={siteUrl}>
  <meta property="og:site_name" content="Nishon Tandukar">
  <meta property="og:locale" content="en_US">
  <meta property="og:image" content={new URL("assets/nishon-og.png", siteUrl)}>
  <meta property="og:image:type" content="image/png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="Nishon Tandukar, Geospatial Software Engineer">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={siteTitle}>
  <meta name="twitter:description" content={heroDescription}>
  <meta name="twitter:image" content={new URL("assets/nishon-og.png", siteUrl)}>
  <meta name="twitter:image:alt" content="Nishon Tandukar, Geospatial Software Engineer">
  <meta name="theme-color" content="#ffffff">
  <script is:inline>
    (() => {
      const saved = localStorage.getItem("nishon-theme");
      const mode = ["light", "dark", "auto"].includes(saved) ? saved : "auto";
      document.documentElement.dataset.themeMode = mode;
      document.documentElement.dataset.theme = mode === "auto"
        ? (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
        : mode;
    })();
  </script>
  <title>{siteTitle}</title>
  <script type="application/ld+json" set:html={JSON.stringify(homeSchema)} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="alternate icon" type="image/png" href="/favicon.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Serif+Display:ital@0;1&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --ink: #333132;
      --muted: #6f7278;
      --paper: #ffffff;
      --card: #f4f4f4;
      --line: #e6e6e6;
      --accent: #0055ff;
      --green: #001acb;
      --radius: 26px;
    }
    html[data-theme="dark"] {
      --ink: #f4f4f4;
      --muted: #a9adb7;
      --paper: #11131a;
      --card: #1a1e29;
      --line: #303542;
      --accent: #738dff;
      --green: #ffb100;
      color-scheme: dark;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      color: var(--ink);
      background:
        radial-gradient(circle at 8% 3%, rgba(0,85,255,.09), transparent 28rem),
        var(--paper);
      font: 400 16px/1.65 "DM Sans", sans-serif;
      -webkit-font-smoothing: antialiased;
    }
    html[data-theme="dark"] body {
      background:
        radial-gradient(circle at 8% 3%, rgba(0,85,255,.2), transparent 30rem),
        radial-gradient(circle at 92% 18%, rgba(255,171,0,.055), transparent 24rem),
        var(--paper);
    }
    body, .nav::before, .featured, .feature-copy, .post-card, .field-photo figcaption, footer {
      transition: color .25s ease, background-color .25s ease, border-color .25s ease;
    }
    a { color: inherit; text-decoration: none; }
    button { font: inherit; }
    .skip-link {
      position: fixed;
      z-index: 100;
      top: 10px;
      left: 10px;
      padding: 10px 15px;
      border-radius: 8px;
      color: var(--paper);
      background: var(--ink);
      font-weight: 700;
      transform: translateY(-160%);
    }
    .skip-link:focus { transform: translateY(0); }
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .ui-icon {
      display: inline-block;
      flex: none;
      width: 16px;
      height: 16px;
      background: currentColor;
      -webkit-mask: var(--icon) center / contain no-repeat;
      mask: var(--icon) center / contain no-repeat;
    }
    .icon-monitor { --icon: url("/assets/icons/monitor.svg"); }
    .icon-sun { --icon: url("/assets/icons/sun.svg"); }
    .icon-moon { --icon: url("/assets/icons/moon.svg"); }
    .icon-arrow-right { --icon: url("/assets/icons/arrow-right.svg"); }
    .icon-external-link { --icon: url("/assets/icons/external-link.svg"); }
    .icon-mail { --icon: url("/assets/icons/mail.svg"); }
    .shell { width: min(1140px, calc(100% - 40px)); margin-inline: auto; }

    .nav {
      position: sticky;
      top: 0;
      z-index: 20;
      isolation: isolate;
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: min(1140px, calc(100% - 40px));
      margin: 0 auto;
      padding: 22px 0 18px;
      border-bottom: 1px solid var(--line);
      backdrop-filter: blur(16px);
    }
    .nav::before {
      content: "";
      position: absolute;
      z-index: -1;
      inset: 0 auto;
      left: 50%;
      width: 100vw;
      transform: translateX(-50%);
      background: rgba(255,255,255,.92);
    }
    html[data-theme="dark"] .nav::before { background: rgba(17,19,26,.92); }
    .logo { font: 800 15px/1 "Manrope", sans-serif; letter-spacing: -.04em; }
    .logo span { display: inline-block; width: 5px; height: 5px; margin: 0 2px 2px; border-radius: 50%; background: var(--accent); }
    .nav-links { display: flex; align-items: center; gap: 26px; color: #505249; font-size: 14px; font-weight: 600; }
    html[data-theme="dark"] .nav-links { color: #c2c5ce; }
    .nav-links a { display: inline-flex; align-items: center; min-height: 44px; }
    .nav-links a:hover, .nav-links a:focus-visible, footer a:hover, footer a:focus-visible { color: var(--accent); }
    .theme-toggle {
      display: inline-grid;
      place-items: center;
      width: 44px;
      height: 44px;
      padding: 0;
      border: 1px solid var(--line);
      border-radius: 50%;
      color: var(--ink);
      background: transparent;
      cursor: pointer;
    }
    .theme-toggle:hover, .theme-toggle:focus-visible { border-color: var(--accent); color: var(--accent); }
    .theme-toggle:active { transform: scale(.94); }
    .theme-toggle .ui-icon { display: none; width: 18px; height: 18px; }
    html[data-theme-mode="auto"] .theme-toggle .icon-monitor,
    html[data-theme-mode="light"] .theme-toggle .icon-sun,
    html[data-theme-mode="dark"] .theme-toggle .icon-moon { display: block; }
    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 0 19px;
      border: 0;
      border-radius: 999px;
      background: var(--ink);
      color: white;
      font-weight: 600;
      cursor: pointer;
      transition: transform .2s, background .2s;
    }
    .button:hover, .button:focus-visible { transform: translateY(-2px); background: var(--accent); }
    html[data-theme="dark"] .button { color: white; background: var(--accent); }
    html[data-theme="dark"] .button:hover { background: #0055ff; }
    .nav .button { min-height: 40px; font-size: 13px; }

    main { overflow-x: clip; }
    .hero { position: relative; isolation: isolate; overflow: visible; margin-bottom: 48px; padding: 68px 0 66px; }
    .hero > *:not(.globe-wrap) { position: relative; z-index: 2; }
    .globe-wrap {
      position: absolute;
      z-index: 0;
      top: 24px;
      right: -35px;
      width: min(470px, 38vw);
      aspect-ratio: 1;
      pointer-events: none;
      opacity: .82;
    }
    #geo-globe { display: block; width: 100%; height: 100%; }
    .globe-caption {
      position: absolute;
      left: 50%;
      bottom: 2%;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      width: max-content;
      padding: 9px 13px;
      border: 1px solid color-mix(in srgb, var(--ink) 18%, transparent);
      border-radius: 999px;
      color: var(--ink);
      background: color-mix(in srgb, var(--paper) 96%, transparent);
      box-shadow: 0 8px 24px rgba(0,0,0,.09);
      font: 700 12px/1 "Manrope", sans-serif;
      letter-spacing: .01em;
      transform: translateX(-50%);
      backdrop-filter: blur(8px);
    }
    .globe-caption::before {
      content: "";
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #ffab00;
      box-shadow: 0 0 0 3px rgba(255,171,0,.16);
    }
    .globe-country-list { display: none; }
    html[data-theme="dark"] .globe-wrap { opacity: .9; }
    .eyebrow {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 24px;
      color: var(--green);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .13em;
      text-transform: uppercase;
    }
    .eyebrow::before { content: ""; width: 32px; height: 2px; background: var(--accent); }
    h1, h2, h3 { margin: 0; }
    h1 {
      max-width: 1000px;
      font: 400 clamp(64px, 9vw, 118px)/.9 "DM Serif Display", serif;
      letter-spacing: -.045em;
    }
    h1 em { color: var(--accent); font-weight: 400; }
    .hero-bottom {
      display: grid;
      grid-template-columns: 1fr 380px;
      gap: 60px;
      align-items: end;
      margin-top: 40px;
      padding-top: 28px;
    }
    .hero-bottom::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: min(610px, 55%);
      border-top: 1px solid var(--line);
    }
    .hero-bottom p { max-width: 610px; margin: 0; color: var(--muted); font-size: 19px; }
    .hero-bottom .hero-role {
      margin-bottom: 12px;
      color: var(--ink);
      font: 700 17px/1.3 "Manrope", sans-serif;
    }
    .hero-meta { display: flex; justify-content: flex-end; gap: 25px; color: var(--muted); font-size: 12px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; }
    .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 26px; font-size: 14px; font-weight: 700; }
    .hero-actions a { display: inline-flex; align-items: center; gap: 7px; }
    .hero-actions .button:hover { color: white; }
    .hero-actions .button-secondary {
      border: 1px solid var(--line);
      color: var(--ink);
      background: color-mix(in srgb, var(--paper) 88%, transparent);
    }
    .hero-actions .button-secondary:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--paper);
    }
    html[data-theme="dark"] .hero-actions .button-secondary {
      color: var(--ink);
      background: color-mix(in srgb, var(--paper) 82%, transparent);
    }

    section { padding: 76px 0; }
    .section-head { display: flex; justify-content: space-between; align-items: end; gap: 30px; margin-bottom: 40px; }
    .label { color: var(--accent); font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; }
    h2 { margin-top: 8px; font: 400 clamp(42px, 5vw, 68px)/1 "DM Serif Display", serif; letter-spacing: -.035em; }

    .featured {
      display: grid;
      grid-template-columns: .92fr 1.08fr;
      overflow: hidden;
      min-height: 500px;
      border-top: 1px solid var(--ink);
      border-bottom: 1px solid var(--ink);
      background: transparent;
    }
    html[data-theme="dark"] .featured {
      border-color: #42495a;
      background: rgba(20,24,34,.72);
    }
    .feature-art {
      position: relative;
      display: grid;
      place-items: center;
      min-height: 380px;
      overflow: hidden;
      background: var(--green);
    }
    .feature-art img { width: 100%; height: 100%; object-fit: cover; filter: saturate(.82) contrast(1.04); }
    .media-credit { position: absolute; left: 18px; bottom: 18px; z-index: 2; padding: 7px 11px; border-radius: 999px; background: rgba(23,24,20,.76); color: white; font-size: 11px; font-weight: 600; backdrop-filter: blur(8px); }
    .map-paper {
      position: relative;
      z-index: 1;
      width: 68%;
      aspect-ratio: 1;
      border-radius: 10px;
      background:
        linear-gradient(120deg, transparent 46%, #0055ff 47%, #0055ff 49%, transparent 50%),
        linear-gradient(35deg, transparent 44%, #ffab00 45%, #ffab00 47%, transparent 48%),
        repeating-linear-gradient(0deg, transparent 0 28px, rgba(0,26,203,.14) 29px 30px),
        repeating-linear-gradient(90deg, transparent 0 28px, rgba(0,26,203,.14) 29px 30px),
        #f5f0df;
      box-shadow: 0 30px 70px rgba(0,0,0,.24);
      transform: rotate(-5deg);
    }
    .map-paper::after { content: "×"; position: absolute; top: 43%; left: 61%; color: var(--accent); font: 700 44px/1 "Manrope"; }
    .feature-copy { display: flex; flex-direction: column; justify-content: center; padding: clamp(32px,5vw,64px); border-left: 1px solid var(--line); }
    html[data-theme="dark"] .feature-copy { background: linear-gradient(145deg, rgba(26,30,41,.94), rgba(17,19,26,.7)); }
    html[data-theme="dark"] .feature-art img { filter: saturate(.72) brightness(.78) contrast(1.08); }
    html[data-theme="dark"] .media-credit { background: rgba(10,12,18,.82); }
    .post-meta { display: flex; flex-wrap: wrap; gap: 10px; color: var(--muted); font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
    .post-meta span:first-child { color: var(--accent); }
    .featured h3 { margin: 22px 0 18px; font: 400 clamp(38px,4vw,58px)/1.02 "DM Serif Display", serif; letter-spacing: -.035em; }
    .featured p { margin: 0 0 32px; color: var(--muted); font-size: 17px; }
    .read-link { display: inline-flex; align-items: center; gap: 10px; width: fit-content; font-weight: 700; }
    .read-link span { color: var(--accent); transition: transform .2s; }
    .read-link:hover span, .read-link:focus-visible span { transform: translateX(4px); }

    .filters { display: flex; flex-wrap: wrap; gap: 18px; margin-bottom: 26px; }
    .filter {
      min-height: 44px;
      padding: 8px 0 5px;
      border: 0;
      border-bottom: 1px solid transparent;
      color: var(--muted);
      background: transparent;
      cursor: pointer;
      font-weight: 600;
    }
    .filter:hover, .filter:focus-visible, .filter.active { border-color: var(--accent); color: var(--ink); }
    .post-grid { display: block; border-bottom: 1px solid var(--line); }
    .post-card {
      display: grid;
      grid-template-columns: 170px minmax(260px,1fr) minmax(220px,.75fr) auto;
      gap: 28px;
      align-items: center;
      min-height: 0;
      padding: 28px 0;
      border: 0;
      border-top: 1px solid var(--line);
      border-radius: 0;
      background: transparent;
      transition: color .2s, padding .2s;
    }
    .post-card:hover { padding-left: 10px; color: var(--accent); }
    html[data-theme="dark"] .post-card:hover { background: rgba(115,141,255,.055); }
    .post-card[hidden] { display: none; }
    .post-card h3 { margin: 0; font: 400 clamp(25px,2.5vw,36px)/1.08 "DM Serif Display", serif; letter-spacing: -.03em; }
    .post-card p { margin: 0; color: var(--muted); font-size: 14px; }
    .post-card .read-link { margin: 0; padding: 10px 0; white-space: nowrap; font-size: 13px; }

    .contact-panel {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 50px;
      align-items: end;
      padding: 58px 0;
      border-top: 1px solid var(--ink);
      border-bottom: 1px solid var(--ink);
    }
    html[data-theme="dark"] .contact-panel { border-color: #42495a; }
    .contact-panel h2 { max-width: 780px; margin-top: 10px; }
    .contact-panel p { max-width: 650px; margin: 22px 0 0; color: var(--muted); font-size: 18px; }
    .contact-panel .button { gap: 9px; min-height: 50px; padding-inline: 23px; white-space: nowrap; }
    .contact-gate { width: min(100%, 340px); }
    .contact-gate .button { width: 100%; margin-top: 12px; }
    .contact-status { min-height: 24px; margin: 12px 0 0; color: var(--muted); font-size: 13px; }
    .contact-status a { color: var(--accent); font-weight: 700; text-decoration: underline; text-underline-offset: 3px; }
    .honeypot {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      clip-path: inset(50%);
      white-space: nowrap;
    }

    .about {
      display: grid;
      grid-template-columns: .75fr 1.25fr;
      gap: 80px;
      padding: clamp(34px,6vw,72px);
      border-radius: 0;
      background: var(--ink);
      color: white;
    }
    html[data-theme="dark"] .about { background: #171a23; }
    html[data-theme="dark"] .about { box-shadow: inset 0 0 0 1px #303542; }
    .about h2 { max-width: 400px; }
    .author-photo { width: 150px; height: 150px; margin-bottom: 28px; border-radius: 50%; object-fit: cover; border: 4px solid #343630; }
    .about-copy { align-self: end; }
    .about-copy p { margin: 0; color: #bfc1b8; font-size: 19px; }
    .naxa-affiliation {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 15px;
      margin-top: 28px;
      padding: 15px 16px;
      border: 1px solid #55574f;
      border-radius: 12px;
      background: rgba(255,255,255,.045);
      transition: border-color .2s ease, transform .2s ease;
    }
    .naxa-affiliation:hover { transform: translateY(-2px); border-color: #8da1ff; }
    .naxa-logo {
      display: block;
      width: 108px;
      height: auto;
      padding: 8px;
      border-radius: 8px;
      background: white;
    }
    .naxa-context strong { display: block; color: white; font-size: 15px; }
    .naxa-context small { display: block; margin-top: 2px; color: #bfc1b8; font-size: 12px; line-height: 1.45; }
    .naxa-affiliation .ui-icon { color: #8da1ff; }
    .topics { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 28px; }
    .topics span { padding: 0 0 4px; border-bottom: 1px solid #55574f; color: #e4e5df; font-size: 13px; }
    .field-photo { margin-top: 0; overflow: hidden; border-radius: 0; background: var(--card); border: 0; }
    .field-photo img { display: block; width: 100%; max-height: 570px; object-fit: cover; }
    html[data-theme="dark"] .field-photo img { filter: brightness(.8) saturate(.78); }
    html[data-theme="dark"] .field-photo figcaption { background: #171a23; }
    .field-photo figcaption { display: flex; justify-content: space-between; gap: 24px; padding: 18px 22px; color: var(--muted); font-size: 13px; }
    .field-photo figcaption a { color: var(--accent); font-weight: 700; }

    footer { display: flex; justify-content: space-between; gap: 20px; padding: 26px 0; border-top: 1px solid var(--line); color: var(--muted); font-size: 13px; }
    .footer-links { display: flex; flex-wrap: wrap; gap: 12px 20px; }
    :focus-visible { outline: 3px solid #0055ff; outline-offset: 4px; }
    html[data-theme="dark"] :focus-visible { outline-color: #9bb0ff; }

    @media (max-width: 820px) {
      .hero-bottom, .featured, .about, .contact-panel { grid-template-columns: 1fr; }
      .hero-meta { justify-content: flex-start; }
      .feature-art { grid-row: 1; }
