  <script>
    import { geoDistance, geoGraticule, geoOrthographic, geoPath } from "d3-geo";
    import { feature } from "topojson-client";
    import countriesAtlas from "world-atlas/countries-110m.json";

    document.getElementById("year").textContent = new Date().getFullYear();
    const filters = document.querySelectorAll(".filter");
    const posts = document.querySelectorAll(".post-card");
    const filterStatus = document.getElementById("filter-status");
    filters.forEach((button) => {
      button.addEventListener("click", () => {
        filters.forEach((item) => {
          item.classList.remove("active");
          item.setAttribute("aria-pressed", "false");
        });
        button.classList.add("active");
        button.setAttribute("aria-pressed", "true");
        const topic = button.dataset.filter;
        let visibleCount = 0;
        posts.forEach((post) => {
          post.hidden = topic !== "all" && post.dataset.topic !== topic;
          if (!post.hidden) visibleCount += 1;
        });
        const label = button.textContent.trim().toLowerCase();
        filterStatus.textContent = topic === "all"
          ? `Showing all ${visibleCount} articles.`
          : `Showing ${visibleCount} ${label} ${visibleCount === 1 ? "article" : "articles"}.`;
      });
    });

    const canvas = document.getElementById("geo-globe");
    const context = canvas.getContext("2d");
    const globeWrap = canvas.closest(".globe-wrap");
    const motionPreference = window.matchMedia("(prefers-reduced-motion: reduce)");
    const mobileGlobe = window.matchMedia("(max-width: 600px)");
    let reducedMotion = motionPreference.matches;
    let globeVisible = true;
    let pageVisible = !document.hidden;
    let lastGlobeDraw = 0;
    const land = feature(countriesAtlas, countriesAtlas.objects.land);
    const countries = feature(countriesAtlas, countriesAtlas.objects.countries);
    const clientCountries = [
      { id: "524", name: "Nepal", point: [84, 28], labelOffset: [9, -12] },
      { id: "036", name: "Australia", point: [134, -25], labelOffset: [9, -8] },
      { id: "840", name: "USA", point: [-100, 39], labelOffset: [9, -9] },
      { id: "756", name: "Switzerland", point: [8.2, 46.8], labelOffset: [-9, -11] },
      { id: "380", name: "Italy", point: [12.5, 42.8], labelOffset: [9, 8] },
      { id: "356", name: "India", point: [79, 22], labelOffset: [-9, 11] },
      { id: "454", name: "Malawi", point: [34.3, -13.3], labelOffset: [-9, -8] }
    ].map((client) => ({
      ...client,
      geometry: countries.features.find((country) => String(country.id).padStart(3, "0") === client.id)
    }));
    const graticule = geoGraticule().step([30, 30])();
    const animationStart = performance.now();
    let frame = null;
    let resizeFrame = null;

    function drawGlobe(timestamp = performance.now()) {
      const dark = document.documentElement.dataset.theme === "dark";
      const bounds = canvas.getBoundingClientRect();
      const maxRatio = mobileGlobe.matches ? 1.25 : 2;
      const ratio = Math.min(window.devicePixelRatio || 1, maxRatio);
      const size = Math.max(1, Math.round(bounds.width));
      if (canvas.width !== size * ratio) {
        canvas.width = size * ratio;
        canvas.height = size * ratio;
      }
      context.setTransform(ratio, 0, 0, ratio, 0, 0);
      context.clearRect(0, 0, size, size);

      const center = size / 2;
      const radius = size * .37;
      const rotation = reducedMotion ? -85 : -85 + ((timestamp - animationStart) * .004) % 360;
      const projection = geoOrthographic()
        .translate([center, center])
        .scale(radius)
        .rotate([rotation, -20, 0])
        .precision(.35);
      const path = geoPath(projection, context);
      const glow = context.createRadialGradient(center - radius * .28, center - radius * .35, radius * .05, center, center, radius * 1.05);
      glow.addColorStop(0, dark ? "rgba(115,141,255,.2)" : "rgba(255,255,255,.9)");
      glow.addColorStop(.58, dark ? "rgba(0,85,255,.09)" : "rgba(0,85,255,.12)");
      glow.addColorStop(1, dark ? "rgba(0,26,203,.025)" : "rgba(0,26,203,.045)");
      context.beginPath();
      path({ type: "Sphere" });
      context.fillStyle = glow;
      context.fill();

      context.beginPath();
      path(graticule);
      context.strokeStyle = dark ? "rgba(151,169,255,.13)" : "rgba(0,26,203,.13)";
      context.lineWidth = .7;
      context.stroke();

      context.beginPath();
      path(land);
      context.fillStyle = dark ? "rgba(115,141,255,.22)" : "rgba(0,85,255,.13)";
      context.fill();
      context.strokeStyle = dark ? "rgba(171,185,255,.48)" : "rgba(0,26,203,.38)";
      context.lineWidth = .9;
      context.stroke();

      context.beginPath();
      path(countries);
      context.strokeStyle = dark ? "rgba(17,19,26,.38)" : "rgba(255,255,255,.7)";
      context.lineWidth = .45;
      context.stroke();

      clientCountries.forEach((client) => {
        if (!client.geometry) return;
        context.beginPath();
        path(client.geometry);
        context.fillStyle = dark ? "rgba(255,177,0,.9)" : "rgba(255,171,0,.88)";
        context.fill();
        context.strokeStyle = dark ? "#ffe0a1" : "#8f5e00";
        context.lineWidth = 1;
        context.stroke();
      });

      const visibleCenter = [-rotation, 20];
      clientCountries.forEach((client) => {
        if (geoDistance(visibleCenter, client.point) >= Math.PI / 2) return;
        const point = projection(client.point);

        context.beginPath();
        context.arc(point[0], point[1], 3, 0, Math.PI * 2);
        context.fillStyle = dark ? "#fff2cf" : "#333132";
        context.fill();
        context.strokeStyle = "#ffab00";
        context.lineWidth = 2;
        context.stroke();

        if (size < 380) return;
        const label = client.name.toUpperCase();
        let alignLeft = client.labelOffset[0] < 0;
        let labelX = point[0] + client.labelOffset[0];
        const labelY = Math.max(10, Math.min(size - 10, point[1] + client.labelOffset[1]));
        context.font = '700 9px "DM Sans", sans-serif';
        const labelWidth = context.measureText(label).width;
        if (alignLeft && labelX - labelWidth < 7) {
          alignLeft = false;
          labelX = point[0] + 9;
        } else if (!alignLeft && labelX + labelWidth > size - 7) {
          alignLeft = true;
          labelX = point[0] - 9;
        }
        context.textAlign = alignLeft ? "right" : "left";
        context.textBaseline = "middle";
        context.fillStyle = dark ? "#f4f4f4" : "#333132";
        context.fillText(label, labelX, labelY);
      });

      context.beginPath();
      path({ type: "Sphere" });
      context.strokeStyle = dark ? "rgba(151,169,255,.48)" : "rgba(0,26,203,.38)";
      context.lineWidth = 1.25;
      context.stroke();
    }

    function animateGlobe(timestamp) {
      if (reducedMotion || !globeVisible || !pageVisible) {
        frame = null;
        return;
      }
      const frameInterval = mobileGlobe.matches ? 1000 / 15 : 1000 / 30;
      if (timestamp - lastGlobeDraw >= frameInterval) {
        drawGlobe(timestamp);
        lastGlobeDraw = timestamp;
      }
      frame = requestAnimationFrame(animateGlobe);
    }

    function stopGlobe() {
      if (frame) cancelAnimationFrame(frame);
      frame = null;
    }

    function startGlobe() {
      stopGlobe();
      if (reducedMotion || !globeVisible || !pageVisible) {
        drawGlobe();
        return;
      }
      frame = requestAnimationFrame(animateGlobe);
    }

    drawGlobe();
    if ("IntersectionObserver" in window) {
      const globeObserver = new IntersectionObserver(([entry]) => {
        globeVisible = entry.isIntersecting;
        if (globeVisible) startGlobe();
        else stopGlobe();
      }, { rootMargin: "100px" });
      globeObserver.observe(globeWrap);
    } else {
      startGlobe();
    }

    document.addEventListener("visibilitychange", () => {
      pageVisible = !document.hidden;
      if (pageVisible) startGlobe();
      else stopGlobe();
    });

    motionPreference.addEventListener("change", (event) => {
      reducedMotion = event.matches;
      startGlobe();
    });

    window.addEventListener("resize", () => {
      if (resizeFrame) cancelAnimationFrame(resizeFrame);
      resizeFrame = requestAnimationFrame(() => {
        resizeFrame = null;
        startGlobe();
      });
    });

    const themeToggle = document.querySelector(".theme-toggle");
    const deviceTheme = matchMedia("(prefers-color-scheme: dark)");
    const themeModes = ["auto", "light", "dark"];
    function applyThemeMode(mode, save = true) {
      const theme = mode === "auto" ? (deviceTheme.matches ? "dark" : "light") : mode;
      document.documentElement.dataset.themeMode = mode;
      document.documentElement.dataset.theme = theme;
      if (save) localStorage.setItem("nishon-theme", mode);
      syncThemeToggle();
      drawGlobe();
    }
    function syncThemeToggle() {
      const mode = document.documentElement.dataset.themeMode || "auto";
      const dark = document.documentElement.dataset.theme === "dark";
      const next = themeModes[(themeModes.indexOf(mode) + 1) % themeModes.length];
      const label = mode === "auto" ? "Auto, following device settings" : mode[0].toUpperCase() + mode.slice(1);
      themeToggle.setAttribute("aria-label", `Theme: ${label}. Switch to ${next}`);
      themeToggle.setAttribute("title", `Theme: ${label}`);
      document.querySelector('meta[name="theme-color"]').content = dark ? "#11131a" : "#ffffff";
    }
    themeToggle.addEventListener("click", () => {
      const mode = document.documentElement.dataset.themeMode || "auto";
      applyThemeMode(themeModes[(themeModes.indexOf(mode) + 1) % themeModes.length]);
    });
    deviceTheme.addEventListener("change", () => {
      if (document.documentElement.dataset.themeMode === "auto") applyThemeMode("auto", false);
    });
    syncThemeToggle();

    const contactGate = document.getElementById("contact-gate");
    const contactStatus = document.getElementById("contact-status");
    const turnstileWidget = contactGate?.querySelector(".cf-turnstile");
    const submitButton = contactGate?.querySelector('button[type="submit"]');

    const readJsonResponse = async (response) => {
      const contentType = response.headers.get("content-type") || "";
      if (!contentType.includes("application/json")) {
        throw new Error("The contact service is unavailable. Please try again later.");
      }
      return response.json();
    };

    const loadTurnstileScript = () => new Promise((resolve, reject) => {
      if (window.turnstile) {
        resolve(window.turnstile);
        return;
      }
      const existing = document.getElementById("turnstile-script");
      if (existing) {
        existing.addEventListener("load", resolve, { once: true });
        existing.addEventListener("error", reject, { once: true });
        return;
      }
      const script = document.createElement("script");
      script.id = "turnstile-script";
      script.src = "https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit";
      script.async = true;
      script.defer = true;
      script.addEventListener("load", resolve, { once: true });
      script.addEventListener("error", () => reject(new Error("The security check did not load.")), { once: true });
      document.head.append(script);
    });

    const waitForTurnstile = () => new Promise((resolve, reject) => {
      if (window.turnstile) return resolve(window.turnstile);

      const startedAt = Date.now();
      const timer = window.setInterval(() => {
        if (window.turnstile) {
          window.clearInterval(timer);
          resolve(window.turnstile);
        } else if (Date.now() - startedAt > 10000) {
          window.clearInterval(timer);
          reject(new Error("The security check did not load."));
        }
      }, 100);
    });

    const initializeTurnstile = async () => {
      try {
        const [response] = await Promise.all([
          fetch("/api/turnstile-config", { headers: { accept: "application/json" } }),
          loadTurnstileScript()
        ]);
        const result = await readJsonResponse(response);
        if (!response.ok || !result.siteKey) {
          throw new Error(result.error || "The security check is not configured.");
        }

        const turnstile = await waitForTurnstile();
        turnstile.render(turnstileWidget, {
          sitekey: result.siteKey,
          action: "turnstile-spin-v2",
          theme: "auto",
          size: "flexible",
          callback: () => {
            submitButton.disabled = false;
            contactStatus.textContent = "";
          },
          "expired-callback": () => {
            submitButton.disabled = true;
            contactStatus.textContent = "Please complete the security check again.";
          },
          "error-callback": () => {
            submitButton.disabled = true;
            contactStatus.textContent = "The security check could not load. Please refresh the page.";
          }
        });
      } catch (error) {
        contactStatus.textContent = error.message || "The security check could not load.";
      }
    };

    if ("IntersectionObserver" in window) {
      const contactObserver = new IntersectionObserver(([entry], observer) => {
        if (!entry.isIntersecting) return;
        observer.disconnect();
        initializeTurnstile();
      }, { rootMargin: "500px" });
      contactObserver.observe(contactGate);
    } else {
      initializeTurnstile();
    }

    contactGate?.addEventListener("submit", async (event) => {
      event.preventDefault();
      submitButton.disabled = true;
      contactStatus.textContent = "Checking…";

      try {
        const response = await fetch(contactGate.action, {
          method: "POST",
          body: new FormData(contactGate),
          headers: { accept: "application/json" }
        });
        const result = await readJsonResponse(response);
        if (!response.ok || !result.email) throw new Error(result.error || "Unable to reveal the email.");

        const link = document.createElement("a");
        link.href = `mailto:${result.email}?subject=Geospatial%20project%20inquiry`;
        link.textContent = result.email;
        contactStatus.replaceChildren("Email Nishon at ", link, ".");
        contactGate.querySelector(".cf-turnstile").hidden = true;
        submitButton.hidden = true;
      } catch (error) {
        contactStatus.textContent = error.message || "Unable to reveal the email. Please try again.";
        window.turnstile?.reset();
      }
    });
  </script>
</body>
</html>
